---
import { Image } from 'astro:assets';
import fieldworkLogo from '../assets/fieldwork-logo.png';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href="/">
			<Image src={fieldworkLogo} alt={SITE_TITLE} width={64} height={64} />
		</a>
		<div class="internal-links">
			<HeaderLink href="/" class="fieldwork-link">Fieldwork</HeaderLink>
			<HeaderLink href="/benchmark" class="fieldwork-link">The Benchmark</HeaderLink>
			<HeaderLink href="/environment" class="fieldwork-link">Environment</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #000000;
		border-bottom: 1px solid rgba(255, 255, 255, 0.35);
	}
	.logo {
		display: flex;
		align-items: center;
		padding: 0.75em 0;
		text-decoration: none;
	}
	.logo img {
		display: block;
		height: 3.5rem;
		width: auto;
		filter: invert(1);
	}
	nav {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}
	.logo {
		position: absolute;
		left: 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
	}
	.internal-links a {
		padding: 1em 0.5em;
		color: #ffffff;
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: #ffffff;
	}
	.internal-links :global(a.fieldwork-link) {
		font-size: 2rem;
		font-weight: 700;
	}
</style>
