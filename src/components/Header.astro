---
import { Image } from 'astro:assets';
import fieldworkLogo from '../assets/fieldwork-logo.png';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href="/">
			<Image src={fieldworkLogo} alt={SITE_TITLE} width={40} height={40} />
		</a>
		<div class="internal-links">
			<HeaderLink href="/" class="fieldwork-link">Fieldwork</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #000000;
		border-bottom: 1px solid rgba(255, 255, 255, 0.35);
	}
	.logo {
		display: flex;
		align-items: center;
		padding: 0.75em 0;
		text-decoration: none;
	}
	.logo img {
		display: block;
		height: 2.25rem;
		width: auto;
		filter: invert(1);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links a {
		padding: 1em 0.5em;
		color: #ffffff;
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: #ffffff;
	}
	.internal-links :global(a.fieldwork-link) {
		font-size: 1.2rem;
		font-weight: 700;
	}
</style>
